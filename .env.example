# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_TO=you@example.com
# Optional. Defaults to "Padel Poll <onboarding@resend.dev>" (Resend's test sender).
# For production, verify a domain in Resend and set this to a sender on it.
EMAIL_FROM="Padel Poll <noreply@yourdomain.com>"

# State store (Upstash Redis or Vercel KV — either pair works)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...

# Optional: lock down /api/cron/check
CRON_SECRET=some-random-string
