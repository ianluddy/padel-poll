# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_TO=you@example.com
# Optional. Defaults to "Padel Poll <onboarding@resend.dev>" (Resend's test sender).
# For production, verify a domain in Resend and set this to a sender on it.
EMAIL_FROM="Padel Poll <noreply@yourdomain.com>"

# WhatsApp (whapi.cloud) — leave unset to skip WhatsApp notifications.
# Token from your whapi.cloud channel dashboard.
WHAPI_TOKEN=
# Recipient phone number(s) in international format (no +, digits only).
# Multiple numbers can be comma-separated.
WHAPI_TO=353871234567
# Optional. Override the whapi.cloud gateway URL (defaults to https://gate.whapi.cloud).
# WHAPI_BASE_URL=https://gate.whapi.cloud

# State store (Upstash Redis or Vercel KV — either pair works)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...

# Optional: lock down /api/cron/check and /api/cron/sessions
CRON_SECRET=some-random-string

# Project Padel account credentials — used by /api/cron/sessions to scrape "Next Activities"
USERNAME=
PASSWORD=

# Google Calendar sync — leave unset to skip.
# /api/cron/sessions will mirror your upcoming bookings into the calendar below.
# 1. Enable the Google Calendar API and create an OAuth 2.0 Client ID at
#    https://console.cloud.google.com/apis/credentials.
# 2. Run the OAuth flow once (e.g. via the Google OAuth Playground) with the
#    scope https://www.googleapis.com/auth/calendar.events to obtain a
#    long-lived refresh token.
# 3. Optional: GOOGLE_CALENDAR_ID defaults to "primary".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# GOOGLE_CALENDAR_ID=primary
